APP_NAME=AI Resume Analyzer
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/ai_resume_analyzer
CORS_ORIGINS=*

EMBEDDING_DIMENSIONS=384
USE_TRANSFORMERS=false
TRANSFORMER_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
MAX_RESUME_SIZE_MB=5

SKILL_SCORE_WEIGHT=0.40
SEMANTIC_SCORE_WEIGHT=0.25
EXPERIENCE_SCORE_WEIGHT=0.15
EDUCATION_SCORE_WEIGHT=0.10
FORMATTING_SCORE_WEIGHT=0.10

JWT_SECRET_KEY=change-this-secret-in-production
JWT_EXPIRE_MINUTES=60

