# Cache
CACHE_DIR=cache
CACHE_ENABLED=true
ANSWER_CACHE_ENABLED=true

# Models
MODEL_NAME=local-grounded
EMBEDDING_MODEL=local-hashing

# Runtime
LOG_LEVEL=INFO
