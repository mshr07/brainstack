# Jira source
JIRA_DATA_PATH=data/dummy_jira_tickets.json
JIRA_BASE_URL=
JIRA_PROJECT_KEY=AICB
JIRA_EMAIL=
JIRA_API_TOKEN=

# Retrieval
RETRIEVAL_TOP_K=6
RETRIEVAL_MAX_CONTEXT_CHARS=6000
