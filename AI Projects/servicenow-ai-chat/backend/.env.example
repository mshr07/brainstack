APP_NAME=Jira Ticket RAG Chatbot
ENVIRONMENT=local
DATABASE_URL=sqlite:///./jira_rag_local.db
POSTGRES_USER=jira
POSTGRES_PASSWORD=jira
POSTGRES_DB=jira_rag
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
AUTO_SYNC_MOCK=true
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=AICB
MOCK_JIRA_DATA_PATH=../sample_data/jira_tickets.json
MODEL_NAME=local-grounded
EMBEDDING_MODEL=local-hashing
RETRIEVAL_TOP_K=6
TOKEN_BUDGET_CHARS=6000
RERANKING_ENABLED=true
LOG_LEVEL=INFO
